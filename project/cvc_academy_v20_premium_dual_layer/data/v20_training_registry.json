    {
      "id": "micro_debrief",
      "title": "Micro debrief",
      "duration_min": 8,
      "steps": [
        "definir o quase erro",
        "explicitar o gatilho",
        "nomear a correcao prudente",
        "fechar com uma frase operacional"
      ]
    },
    {
      "id": "osce_station",
      "title": "OSCE station",
      "duration_min": 12,
      "steps": [
        "apresentar o caso",
        "observar o desempenho",
        "pontuar rubrica",
        "encerrar com checklist e take-home"
      ]
    },
    {
      "id": "visual_review_round",
      "title": "Visual review round",
      "duration_min": 15,
      "steps": [
        "abrir um board ou atlas",
        "pedir leitura estruturada",
        "contrastar escolha prudente e perigosa",
        "ligar ao caso real do dia"
      ]
    }
  ],
  "feedback_scale": [
    {
      "id": "elegante",
      "score": 3,
      "summary": "resolve com clareza, proporcao e baixo dano"
    },
    {
      "id": "prudente",
      "score": 2,
      "summary": "segura o dano e mantem a direcao clinica"
    },
    {
      "id": "aceitavel",
      "score": 1,
      "summary": "nao compromete, mas ainda sobra folga tecnica"
    },
    {
      "id": "precipitado",
      "score": -1,
      "summary": "anda rapido demais para o que o caso suporta"
    },
    {
      "id": "desproporcional",
      "score": -2,
      "summary": "entrega mais invasao ou risco que o necessario"
    },
    {
      "id": "perigoso",
